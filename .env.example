# このファイルを .env にコピーして使う（.env は .gitignore 済みのため平文がgitに入らない）

# kabuステーションのAPIシステム設定で発行するAPIパスワード（必須）。
# 証券口座のログインパスワード・取引暗証番号とは別物なので注意（kabuステーション
# アプリの「APIシステム設定」画面で設定したパスワードを使うこと）。
KABU_API_PASSWORD=

# ダッシュボードのアクセストークン（任意）。設定すると認証が有効になる。
# host を 0.0.0.0（LAN公開）にする場合は設定を強く推奨。
KABU_DASHBOARD_TOKEN=

# Discord Webhook URL（任意）。設定すると取引情報（銘柄・数量・価格・損益）がDiscordへ送信される。
# 取得方法は docs/通知設定ガイド.md を参照。
DISCORD_WEBHOOK_URL=

# X（旧Twitter）APIの認証情報（任意）。4つすべて設定し、config.yamlのx.enabledをtrueにすると
# 平日17:30に日次損益サマリが自動投稿される。取得手順は docs/日次レポート投稿ガイド.md を参照。
# Read and Write 権限が必須（権限変更後はAccess Tokenの再生成が必要）。
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Discord日次レポート用Webhook URL（任意・無料）。設定し、config.yamlのdiscord_report.enabledを
# trueにすると、X同様の日次損益サマリが平日17:30にDiscordへ自動投稿される。
# 上のDISCORD_WEBHOOK_URL（異常時アラート用）とは別チャンネル想定。同じURLでも構わない。
DISCORD_REPORT_WEBHOOK_URL=
